# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.

# Required — vault login gate
VAULT_PASSWORD=your-password-here

# Poncho — hosted research agent (research / write / format).
# The key IS your agent; requests go to https://tryponcho.com. Nothing to deploy.
# Get it from Poncho: Settings > Developers.
PONCHO_API_KEY=pk_poncho_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional overrides:
# PONCHO_API_BASE=https://tryponcho.com
# PONCHO_MODEL=claude-sonnet-4-6

# MongoDB Atlas — vault content store (coming: single-user now, userId baked in)
# MONGODB_URI=mongodb+srv://user:pass@cluster.xxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=cairn

# Optional — for in-browser editor GitHub commits
# GITHUB_TOKEN=
# GITHUB_REPO=
